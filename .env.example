# ============================================================================
# Chaos-Sec: Environment Variables
# ============================================================================
# Copy this file to .env and update the values for your environment.
#   cp .env.example .env
#
# IMPORTANT: Never commit the .env file to version control.
# ============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
APP_ENV=development                          # development | staging | production
APP_NAME=Chaos-Sec                           # Application display name
SERVER_PORT=8080                             # Backend API server port
METRICS_PORT=9090                            # Prometheus metrics port

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
LOG_LEVEL=debug                              # debug | info | warn | error
LOG_FORMAT=json                              # json | text

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------
DATABASE_HOST=localhost                      # Database host (use "postgres" in Docker)
DATABASE_PORT=5432                           # Database port
DATABASE_NAME=chaossec                       # Database name
DATABASE_USER=chaossec_admin                 # Database user
DATABASE_PASSWORD=chaossec_local_dev_password # Database password (CHANGE IN PRODUCTION)
DATABASE_SSL_MODE=disable                    # disable | require | verify-ca | verify-full
DATABASE_MAX_CONNECTIONS=50                  # Max connection pool size
DATABASE_MIGRATIONS_DIR=file://backend/migrations  # Migrations source path

# Full database URL for golang-migrate (overrides individual settings above)
DATABASE_URL=postgres://chaossec_admin:chaossec_local_dev_password@localhost:5432/chaossec?sslmode=disable

# ----------------------------------------------------------------------------
# Redis (Cache & Session Store)
# ----------------------------------------------------------------------------
REDIS_HOST=localhost                         # Redis host (use "redis" in Docker)
REDIS_PORT=6379                              # Redis port
REDIS_PASSWORD=chaossec_redis_local_password # Redis password (CHANGE IN PRODUCTION)
REDIS_DB=0                                   # Redis database index
REDIS_MAX_RETRIES=3                          # Max retry attempts on connection failure
REDIS_POOL_SIZE=10                           # Connection pool size

# ----------------------------------------------------------------------------
# RabbitMQ (Message Queue)
# ----------------------------------------------------------------------------
RABBITMQ_URL=amqp://chaossec:chaossec_rabbitmq_local_password@localhost:5672/ # AMQP connection URL
RABBITMQ_USER=chaossec                       # RabbitMQ username
RABBITMQ_PASSWORD=chaossec_rabbitmq_local_password # RabbitMQ password (CHANGE IN PRODUCTION)
RABBITMQ_VHOST=/                             # RabbitMQ virtual host
RABBITMQ_EXPERIMENT_QUEUE=chaos-sec-experiments # Queue name for experiment jobs

# ----------------------------------------------------------------------------
# Authentication (JWT)
# ----------------------------------------------------------------------------
JWT_SECRET=local-dev-jwt-secret-change-in-production-32chars!! # JWT signing key (MUST CHANGE IN PRODUCTION)
JWT_EXPIRY=3600                              # Access token expiry in seconds (1 hour)
JWT_REFRESH_EXPIRY=604800                    # Refresh token expiry in seconds (7 days)
JWT_ISSUER=chaos-sec                        # Token issuer claim
JWT_AUDIENCE=chaos-sec-users                # Token audience claim

# ----------------------------------------------------------------------------
# SIEM Integration
# ----------------------------------------------------------------------------
SIEM_ENABLED=true                            # Enable SIEM alert forwarding
SIEM_PROVIDER=mock                           # mock | splunk | elastic | qradar
SIEM_ENDPOINT=http://localhost:8089          # SIEM API endpoint (use "http://mock-siem:8089" in Docker)
SIEM_API_KEY=                                # API key for SIEM authentication (if required)
SIEM_BATCH_SIZE=100                          # Number of alerts to batch before sending
SIEM_FLUSH_INTERVAL=30                      # Seconds between batch flushes

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true                      # Enable rate limiting
RATE_LIMIT_REQUESTS=100                      # Max requests per window
RATE_LIMIT_WINDOW=60s                        # Time window for rate limiting

# ----------------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080 # Comma-separated allowed origins
CORS_ALLOW_CREDENTIALS=true                  # Allow credentials in CORS requests
CORS_MAX_AGE=86400                           # Preflight cache duration in seconds

# ----------------------------------------------------------------------------
# Kubernetes / Chaos Engineering
# ----------------------------------------------------------------------------
KUBECONFIG=                                  # Path to kubeconfig (leave empty for in-cluster)
EXPERIMENT_NAMESPACE=chaos-sec-experiments   # Namespace for experiment pods
DEFAULT_POD_TIMEOUT=600s                     # Default timeout for experiment pods
MAX_CONCURRENT_EXPERIMENTS=5                 # Max parallel running experiments
EXPERIMENT_SERVICE_ACCOUNT=chaos-sec-runner  # Service account for experiment pods
CHAOS_IMAGE_PULL_POLICY=IfNotPresent         # Always | IfNotPresent | Never

# ----------------------------------------------------------------------------
# Kind Cluster (Development)
# ----------------------------------------------------------------------------
KIND_CLUSTER_NAME=chaos-sec                  # Name of the Kind cluster
KIND_NODE_IMAGE=kindest/node:v1.28.0         # Kind node image to use

# ----------------------------------------------------------------------------
# Docker Registry
# ----------------------------------------------------------------------------
DOCKER_REGISTRY=chaos-sec                    # Docker image registry prefix
DOCKER_TAG=latest                            # Default image tag

# ----------------------------------------------------------------------------
# Frontend
# ----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8080/api/v1    # Backend API URL (used by Vite at build time)
VITE_WS_URL=ws://localhost:8080/ws           # Backend WebSocket URL
NODE_ENV=development                         # development | production

# ----------------------------------------------------------------------------
# Monitoring (Prometheus & Grafana)
# ----------------------------------------------------------------------------
METRICS_ENABLED=true                         # Enable Prometheus metrics endpoint
PROMETHEUS_SCRAPE_INTERVAL=15s               # Scrape interval for Prometheus
GRAFANA_ADMIN_USER=admin                     # Grafana admin username
GRAFANA_ADMIN_PASSWORD=admin                  # Grafana admin password (CHANGE IN PRODUCTION)

# ----------------------------------------------------------------------------
# Mock SIEM (used by Docker Compose)
# ----------------------------------------------------------------------------
SIEM_PORT=8089                               # Mock SIEM server port
SIEM_LOG_LEVEL=info                          # Mock SIEM log level
